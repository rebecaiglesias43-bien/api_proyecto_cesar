*.sql
*.sqlite
*.db

# Variables de entorno
.env
.env.local
.env.*.local

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log

# Archivos de sistema
Thumbs.db
desktop.ini
"@ | Out-File -FilePath .gitignore -Encoding UTF8